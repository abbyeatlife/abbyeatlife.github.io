            <tr><td>無糖豆漿（100ml）</td><td>3.5 g</td><td>35 kcal</td><td>每天 400ml 補充</td></tr>
          </tbody>
        </table>
        </div>
        <div class="warn-box" style="margin-top:10px;">油炸、醬燒、紅燒等烹調方式會讓熱量大幅提升。同樣一塊雞腿，水煮 vs 炸排骨可以差 2–3 倍熱量。</div>
      </div>
    </div>

    <!-- B3 -->
    <div class="section" id="sec-b3">
      <div class="section-header">
        <div class="section-badge badge-b">B3</div>
        <div class="section-title">外食潛在熱量：你以為吃少，其實沒有</div>
      </div>

      <div class="card">
        <div class="card-label">外食熱量黑洞——你看不見的那些</div>
        <div class="info-row">
          <div class="info-icon" style="color:var(--terra);">💧</div>
          <div class="info-text"><strong>炒菜用油</strong>：一般便當炒青菜用 1–2 湯匙油 = 120–240 kcal，但你以為是健康蔬菜</div>
        </div>
        <div class="info-row">
          <div class="info-icon" style="color:var(--terra);">🍯</div>
          <div class="info-text"><strong>醬汁</strong>：便當醬汁、薑燒醬、照燒醬通常含糖 + 油，1份額外加 100–200 kcal</div>
        </div>
        <div class="info-row">
          <div class="info-icon" style="color:var(--terra);">🍳</div>
          <div class="info-text"><strong>裹粉炸物</strong>：鹹酥雞、炸魚塊的麵衣本身就吸油，比你想像的熱量高 30–50%</div>
        </div>
      </div>

      <div class="card">
        <div class="card-label">Jade 飲食中的具體例子拆解</div>
        <table class="compare-table" style="margin-top:8px;">
          <thead>
            <tr><th style="width:35%;">你點的</th><th style="width:20%;">你以為</th><th style="width:22%;">實際約</th><th style="width:23%;">多的在哪</th></tr>
          </thead>
          <tbody>
            <tr>
              <td>排骨便當（飯少）</td>
              <td>600 kcal</td>
              <td class="hl-red">750–850 kcal</td>
              <td>排骨裹粉炸＋炒菜油</td>
            </tr>
            <tr>
              <td>鹹酥雞 5 塊</td>
              <td>200 kcal</td>
              <td class="hl-red">300–350 kcal</td>
              <td>麵衣吸油</td>
            </tr>
            <tr>
              <td>薑燒豬肉包</td>
              <td>350 kcal</td>
              <td class="hl-red">420–480 kcal</td>
              <td>薑燒醬含糖油</td>
            </tr>
            <tr>
              <td>麻辣鍋底</td>
              <td>低卡</td>
              <td class="hl-red">300–500 kcal</td>
              <td>麻辣油＋牛油底</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="card">
        <div class="card-label">3個點餐技巧，馬上降低外食熱量</div>
        <div class="week-goal">
          <div class="goal-num">1</div>
          <div class="goal-text">選「滷／烤／蒸」取代「炸」
            <div class="goal-sub">同樣的肉，烤雞腿 vs 炸雞腿差 150–200 kcal，一餐就省下來了</div>
          </div>
        </div>
        <div class="week-goal">
          <div class="goal-num">2</div>
          <div class="goal-text">醬汁另外放或減半
            <div class="goal-sub">直接請店家「醬汁少放」，或自己先倒掉一半，簡單有效</div>
          </div>
        </div>
        <div class="week-goal">
          <div class="goal-num">3</div>
          <div class="goal-text">炸物限量：一餐最多一樣
            <div class="goal-sub">不用完全不吃，但鹹酥雞＋炸魚塊同時出現就超標了。選一樣吃，另一樣換成燙青菜或豆腐</div>
          </div>
        </div>
        <div class="tip-box"><strong>下週可以馬上執行的一件事</strong>：便當請店家「醬汁另外附」，自己控制用量。</div>
      </div>
    </div>

  </main>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script>
function show(id, btn) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('visible'));
  document.querySelectorAll('.sidebar-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('sec-' + id).classList.add('visible');
  btn.classList.add('active');
}

function calcTDEE() {
  const bmr = parseFloat(document.getElementById('bmr').value);
  const act = parseFloat(document.getElementById('activity').value);
  if (!bmr || isNaN(bmr)) {
    document.getElementById('tdee-display').textContent = '——';
    document.getElementById('target-display').textContent = '——';
    return;
  }
  const tdee = Math.round(bmr * act);
  const target = Math.round(tdee - 450);
  document.getElementById('tdee-display').textContent = tdee.toLocaleString();
  document.getElementById('target-display').textContent = target.toLocaleString();
  calcMeals();
}

function calcMacros() {
  const p = parseFloat(document.getElementById('prot-g').value) || 0;
  const f = parseFloat(document.getElementById('fat-g').value) || 0;
  const c = parseFloat(document.getElementById('carb-g').value) || 0;
  const pKcal = Math.round(p * 4);
  const fKcal = Math.round(f * 9);
  const cKcal = Math.round(c * 4);
  const total = pKcal + fKcal + cKcal;
  document.getElementById('prot-kcal').textContent = p ? pKcal : '——';
  document.getElementById('fat-kcal').textContent = f ? fKcal : '——';
  document.getElementById('carb-kcal').textContent = c ? cKcal : '——';
  document.getElementById('total-kcal').textContent = total ? total.toLocaleString() : '——';
  if (total > 0) {
    document.getElementById('prot-bar').style.width = Math.min(100, Math.round(pKcal/total*100)) + '%';
    document.getElementById('fat-bar').style.width = Math.min(100, Math.round(fKcal/total*100)) + '%';
    document.getElementById('carb-bar').style.width = Math.min(100, Math.round(cKcal/total*100)) + '%';
  }
  calcMeals();
}

function calcMeals() {
  const protG = parseFloat(document.getElementById('prot-g').value) || 0;
  const fatG = parseFloat(document.getElementById('fat-g').value) || 0;
  const carbG = parseFloat(document.getElementById('carb-g').value) || 0;
  const totalKcal = Math.round(protG*4 + fatG*9 + carbG*4);
  const rows = document.querySelectorAll('.meal-row');
  const pctInputs = document.querySelectorAll('.pct-input');
  let totalPct = 0;
  pctInputs.forEach(i => totalPct += (parseFloat(i.value) || 0));
  document.getElementById('pct-total').textContent = Array.from(pctInputs).map(i => i.value||0).join('+') + ' = ' + totalPct;
  rows.forEach((row, i) => {
    const pct = parseFloat(pctInputs[i].value) || 0;
    const mealKcal = totalKcal ? Math.round(totalKcal * pct / 100) : 0;
    const mealProt = protG ? Math.round(protG * pct / 100) : 0;
    row.querySelector('.meal-kcal').textContent = mealKcal ? mealKcal + ' kcal' : '——';
    row.querySelector('.meal-prot').textContent = mealProt ? '蛋白質 ' + mealProt + ' g' : '蛋白質 ——';
  });
}

const isDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
const gridColor = isDark ? 'rgba(255,255,255,0.07)' : 'rgba(0,0,0,0.06)';
const textColor = isDark ? '#aaa' : '#6b5e52';

new Chart(document.getElementById('weightChart'), {
  type: 'line',
  data: {
    labels: ['5/19 二','5/20 三','5/21 四','5/22 五','5/23 六','5/24 日'],
    datasets: [{
      label: '體重 (kg)',
      data: [74, 73.2, 73.4, 73.9, 75.2, 74.6],
      borderColor: '#8B9E7E',
      backgroundColor: 'rgba(139,158,126,0.08)',
      pointBackgroundColor: '#8B9E7E',
      pointRadius: 5,
      tension: 0.3,
      fill: true,
    },{
      label: '週均 74.1 kg',
      data: [74.1,74.1,74.1,74.1,74.1,74.1],
      borderColor: '#C17F59',
      borderDash: [5,4],
      pointRadius: 0,
      borderWidth: 1.5,
    }]
  },
  options: {
    responsive: true, maintainAspectRatio: false,
    plugins: {
      legend: { display: false },
      tooltip: { callbacks: { label: ctx => ctx.dataset.label + ': ' + ctx.parsed.y + ' kg' }}
    },
    scales: {
      x: { ticks: { color: textColor, font: { size: 11 }, autoSkip: false }, grid: { color: gridColor } },
      y: { min: 72, max: 76, ticks: { color: textColor, font: { size: 11 }, callback: v => v + ' kg' }, grid: { color: gridColor } }
    }
  }
});

new Chart(document.getElementById('progressChart'), {
  type: 'line',
  data: {
    labels: ['現在','第2週','第4週','第6週','第8週','第10週','第12週','第14週','第16週'],
    datasets: [{
      label: '預估體重',
      data: [74.1, 73.4, 72.7, 72.0, 71.2, 70.4, 69.5, 68.0, 66.5],
      borderColor: '#8B9E7E',
      backgroundColor: 'rgba(139,158,126,0.08)',
      pointBackgroundColor: '#8B9E7E',
      pointRadius: 4,
      tension: 0.3, fill: true,
    },{
      label: '目標 65 kg',
      data: [65,65,65,65,65,65,65,65,65],
      borderColor: '#C17F59',
      borderDash: [5,4],
      pointRadius: 0,
      borderWidth: 1.5,
    }]
  },
  options: {
    responsive: true, maintainAspectRatio: false,
    plugins: {
      legend: { display: false },
      tooltip: { callbacks: { label: ctx => ctx.parsed.y.toFixed(1) + ' kg' }}
    },
    scales: {
      x: { ticks: { color: textColor, font: { size: 11 } }, grid: { color: gridColor } },
      y: { min: 63, max: 76, ticks: { color: textColor, font: { size: 11 }, callback: v => v + ' kg' }, grid: { color: gridColor } }
    }
  }
});
</script>
</body>
