        position: 'bottom',
        labels: { color: tc, font: { size: 11 }, boxWidth: 12, padding: 12 }
      }
    },
    scales: {
      x: { ticks: { color: tc, font: { size: 10 } }, grid: { color: gc } },
      y: { min: 70, max: 180, ticks: { color: tc, font: { size: 10 }, callback: v => v + ' mg/dL' }, grid: { color: gc } }
    }
  }
});
</script>
</body>
